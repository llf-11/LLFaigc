# RunningHub OpenAPI 配置
# 复制为 .env 并填入实际值

# API 基础地址
RH_API_BASE_URL=https://www.runninghub.cn/openapi/v2

# API 密钥
RH_API_KEY=your-api-key-here

# API 请求超时（秒）
RH_API_TIMEOUT=60

# 轮询间隔（秒）
RH_API_POLLING_INTERVAL=5

# 最大轮询时间（秒）
RH_API_MAX_POLLING_TIME=600

# 上传超时（秒）
RH_UPLOAD_TIMEOUT=60

# 可选：覆盖 ffmpeg / ffprobe 可执行文件或其 bin 目录
# 用于 SparkVideo VIDEO 素材预处理
# RH_FFMPEG_PATH=
# RH_FFPROBE_PATH=

# 可选：自定义自动下载后的本地缓存目录
# RH_FFMPEG_CACHE_DIR=

# 可选：自定义 FFmpeg 下载地址（适用于网络受限环境或企业内网镜像）
# 默认依次尝试 GitHub Releases -> gyan.dev，设置后仅使用指定地址
# RH_FFMPEG_DOWNLOAD_URL=

# 可选：设为 1 可关闭 Windows 自动下载
# RH_DISABLE_AUTO_FFMPEG_DOWNLOAD=0
